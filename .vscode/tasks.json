{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: install",
      "type": "shell",
      "command": "npm",
      "args": ["install"],
      "problemMatcher": ["$npm"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "npm: build",
      "type": "shell",
      "command": "npm",
      "args": ["run", "build"],
      "problemMatcher": ["$tsc"],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "npm: dev (core)",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev", "-w", "core"],
      "problemMatcher": ["$tsc"],
      "isBackground": true,
      "group": "build"
    },
    {
      "label": "npm: dev (mcp-server)",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev", "-w", "mcp-server"],
      "isBackground": true,
      "group": "build"
    },
    {
      "label": "npm: test",
      "type": "shell",
      "command": "npm",
      "args": ["run", "test", "-w", "core"],
      "problemMatcher": ["$jest"],
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "npm: lint",
      "type": "shell",
      "command": "npm",
      "args": ["run", "lint"],
      "problemMatcher": ["$eslint"],
      "group": "build"
    },
    {
      "label": "Start MCP Server",
      "type": "shell",
      "command": "npm",
      "args": ["start", "-w", "mcp-server"],
      "isBackground": false,
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "new"
      }
    }
  ]
}
